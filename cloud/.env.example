# ── Maestro cloud relay ────────────────────────────────────────────────────

# Secrets (required)
MAESTRO_SECRET=change-me-to-a-random-string           # daemon/worker bearer
MAESTRO_PASSWORD=change-me-to-a-passphrase            # PWA login
SUITE_API_KEY=change-me-for-suite-apps                # cross-app bearer
PORT=3750

# ── Suite integration (required for /api/gloss/voice proxy) ────────────────
GLOSS_URL=https://gloss-nc.fly.dev
GLOSS_API_KEY=change-me

# ── Suite log collector URLs (optional — collector skips missing apps) ─────
COMMS_URL=
BLACK_URL=
SCRIBE_URL=
PULSE_URL=
RECALL_URL=

# ── GitHub (for auto-PR + repo metadata) ───────────────────────────────────
GITHUB_TOKEN=                                         # fine-grained token
GITHUB_DEFAULT_OWNER=                                 # e.g. your-user

# ── Claude / Gemini (SDK-level; `claude -p` uses local auth) ───────────────
CLAUDE_MODEL=claude-sonnet-4-5-20250929               # used by claude -p in reflection + auto-pr
GEMINI_API_KEY=AIza...

# ── Auto-PR loop ──────────────────────────────────────────────────────────
# When false (default), the improvement agent writes proposals to
# tasks.md without opening PRs. Flip to true after manual review.
MAESTRO_AUTO_PR=false
MAESTRO_SELF_IMPROVE_DRY=true                         # auto-pr.js plans only

# ── Push notifications (SPEC 6) ────────────────────────────────────────────
# Generate with:  node -e "console.log(require('web-push').generateVAPIDKeys())"
# Then: fly secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=... -a maestro-nc
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ── Scheduling ─────────────────────────────────────────────────────────────
CLOUD_NIGHTLY_KICKOFF_UTC_HOUR=5                      # ~midnight Central

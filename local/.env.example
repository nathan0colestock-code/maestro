# ── Maestro local daemon ───────────────────────────────────────────────────

# Required
GEMINI_API_KEY=AIza...
MAESTRO_CLOUD_URL=https://your-app.fly.dev
MAESTRO_SECRET=change-me-to-a-random-string

# Auto-behavior
AUTO_LAUNCH_SESSIONS=false                            # daemon launches Claude workers
AUTO_MERGE_ON_TESTS_PASS=false                        # promote done→merge_requested

# ── Suite API key (for log-collector reads) ────────────────────────────────
SUITE_API_KEY=change-me-for-suite-apps

# ── Suite app URLs for the log collector (optional) ────────────────────────
GLOSS_URL=
COMMS_URL=
BLACK_URL=
SCRIBE_URL=
PULSE_URL=
RECALL_URL=

# ── GitHub (for auto-PR runner, G+H) ───────────────────────────────────────
GITHUB_TOKEN=
GITHUB_DEFAULT_OWNER=

# ── Self-improvement loop ──────────────────────────────────────────────────
MAESTRO_AUTO_PR=false
MAESTRO_SELF_IMPROVE_DRY=true                         # auto-pr.js dry-run default

# ── Model selection ────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-5-20250929               # used by claude -p
GEMINI_ROUTER_MODEL=gemini-2.5-flash
GEMINI_DEFINITION_MODEL=gemini-2.0-flash

# ── Push notifications (SPEC 6) ────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ── Pipeline timeouts (M-I-05) ─────────────────────────────────────────────
MAESTRO_PHASE_TIMEOUT_MS=180000                       # 180s per pipeline phase
